# Usage:
# docker compose --env-file backend/.env -f docker-compose.backend.yml up -d --build

# Compose / container defaults
TZ=Asia/Shanghai
YUNXIA_HTTP_PORT=8080
ARIA2_RPC_PORT=6800
ARIA2_LISTEN_PORT=6888
ARIA2_MAX_CONCURRENT_DOWNLOADS=5

# Optional Bangumi RSS sidecars. Disabled by default; start with:
# docker compose --env-file backend/.env -f docker-compose.backend.yml --profile bangumi up -d
AUTOBANGUMI_PORT=7892
QBITTORRENT_WEBUI_PORT=8081
QBITTORRENT_BT_PORT=6889
YUNXIA_AUTOBANGUMI_IMAGE=ghcr.io/estrellaxd/auto_bangumi:latest
YUNXIA_QBITTORRENT_IMAGE=lscr.io/linuxserver/qbittorrent:latest
PUID=1000
PGID=1000
UMASK=022

# Docker build network.
# 默认 host 是为了兼容 Linux 测试机上 `http_proxy=http://127.0.0.1:7890` 这类宿主机本地代理；
# 若目标 Docker 环境不支持 host build network，可改为 default，并把代理地址改成容器可访问地址。
YUNXIA_DOCKER_BUILD_NETWORK=host

# Yunxia backend container defaults
YUNXIA_SERVER_HOST=0.0.0.0
YUNXIA_SERVER_PORT=8080
YUNXIA_SERVER_MODE=release

# Runtime paths inside backend container
YUNXIA_DATABASE_DSN=/app/data/database.db
YUNXIA_STORAGE_DATA_DIR=/app/data/storage
YUNXIA_STORAGE_TEMP_DIR=/app/data/temp

# Security
YUNXIA_JWT_SECRET=change-me-in-production

# Aria2 integration
YUNXIA_ARIA2_RPC_URL=http://aria2:6800/jsonrpc
YUNXIA_ARIA2_RPC_SECRET=

# Note:
# If you want offline downloads to be browsable by Yunxia immediately,
# create a custom local source whose base_path points to /downloads.
#
# If you enable AutoBangumi, configure its downloader as:
# - qBittorrent host: qbittorrent
# - qBittorrent port: 8080
# - download path: /downloads/Bangumi
# Then create a Yunxia local source:
# - mount_path: /bangumi
# - base_path: /downloads
# - root_path: /Bangumi
