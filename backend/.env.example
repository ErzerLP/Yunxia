# Usage:
# docker compose --env-file backend/.env -f docker-compose.backend.yml up -d --build

# Compose / container defaults
TZ=Asia/Shanghai
YUNXIA_HTTP_PORT=8080
ARIA2_RPC_PORT=6800
ARIA2_LISTEN_PORT=6888
ARIA2_MAX_CONCURRENT_DOWNLOADS=5
# Docker build network.
# 默认 host 是为了兼容 Linux 测试机上 `http_proxy=http://127.0.0.1:7890` 这类宿主机本地代理；
# 若目标 Docker 环境不支持 host build network，可改为 default，并把代理地址改成容器可访问地址。
YUNXIA_DOCKER_BUILD_NETWORK=host

# Yunxia backend container defaults
YUNXIA_SERVER_HOST=0.0.0.0
YUNXIA_SERVER_PORT=8080
YUNXIA_SERVER_MODE=release

# Runtime paths inside backend container
YUNXIA_DATABASE_DSN=/app/data/database.db
YUNXIA_STORAGE_DATA_DIR=/app/data/storage
YUNXIA_STORAGE_TEMP_DIR=/app/data/temp

# Security
YUNXIA_JWT_SECRET=change-me-in-production

# Aria2 integration
YUNXIA_ARIA2_RPC_URL=http://aria2:6800/jsonrpc
YUNXIA_ARIA2_RPC_SECRET=
# Backend 与 aria2 共同可见的下载卷路径。离线下载会进入该目录下的 staging 子目录后再导入存储源。
YUNXIA_ARIA2_DOWNLOAD_DIR=/downloads

# Note:
# 离线下载不需要再把存储源 base_path 指向 /downloads；后端会在下载完成后导入目标挂载源。
